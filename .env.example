# 🌟 言语云³集成中心 - 环境变量配置模板
# 复制此文件为 .env.local 并填写实际值
# ⚠️  .env.local 已在 .gitignore 中，不会提交到版本控制

# ===============================
# 🌐 公共变量（前端可访问 - NEXT_PUBLIC_前缀）
# ===============================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_BRAND_NAME=言语云³集成中心
NEXT_PUBLIC_VERSION=v0.1.0
NEXT_PUBLIC_APP_TITLE=言语云集成中心 - 智能云服务管理平台
NEXT_PUBLIC_SUPPORT_EMAIL=admin@your-domain.com

# ===============================
# 🗄️ PostgreSQL 数据库配置
# ===============================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=yyc3_integration_center
DB_USER=postgres
DB_PASSWORD=your-database-password-here
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=10000
DB_SSL=false

# ===============================
# 🤖 AI/LLM 配置（OpenAI兼容接口）
# ===============================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_ORGANIZATION=
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30000

# ===============================
# 🔑 认证与安全配置
# ===============================
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ===============================
# 📧 邮件服务配置（可选）
# ===============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yanyu.cloud

# ===============================
# 📁 文件上传配置
# ===============================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx
UPLOAD_PATH=./uploads
UPLOAD_PROVIDER=local
UPLOAD_BUCKET=yyc3_uploads

# ===============================
# 📊 应用服务器配置
# ===============================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ===============================
# 🔄 WebSocket 配置（实时功能）
# ===============================
WS_ENABLED=true
WS_PATH=/api/ws
WS_CORS_ORIGIN=http://localhost:3000
WS_MAX_CONNECTIONS=1000
WS_PING_TIMEOUT=5000
WS_PING_INTERVAL=25000

# ===============================
# 🚀 性能优化配置
# ===============================
ENABLE_COMPRESSION=true
CACHE_DURATION=300

# ===============================
# 🌍 国际化配置
# ===============================
DEFAULT_LOCALE=zh-CN
SUPPORTED_LOCALES=zh-CN,en-US
TIMEZONE=Asia/Shanghai

# ===============================
# 🔒 安全配置
# ===============================
HELMET_ENABLED=true
HTTPS_ONLY=false
TRUST_PROXY=false
SESSION_SECRET=your-session-secret-here
CSRF_TOKEN_SECRET=your-csrf-secret-here

# ===============================
# 📈 业务特定配置
# ===============================
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_BATCH_SIZE=10
MAX_CONCURRENT_ANALYSES=5
